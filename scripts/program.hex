// program.hex
// Simple 4 intruction program


// ADDI x1, x0, 5     — load 5 into x1 --> 00500093
//00500093

// ADDI x2, x0, 10    — load 10 into x2 --> 00A00113
//00A00113

// ADD  x3, x1, x2    — x3 = x1 + x2 = 15 --> 002081B3
//002081B3

// ADD  x4, x3, x1    — x4 = x3 + x1 = 20 --> 00308233
//00308233

// Branch program
//00000093
//00500113
//00108093
//FE209EE3
//06300193

// Load Store program
//ADDI x1, x0, 42    — x1 = 42
//ADDI x2, x0, 100   — x2 = base address for memory (byte address)
//SW   x1, 0(x2)     — store 42 to mem[100]
//LW   x3, 0(x2)     — load from mem[100] into x3
//ADDI x4, x3, 1     - Expose the x3 value to verify success
//02A00093
//06400113
//00112023
//00012183
//00118213

//Hazard program
//ADDI x1, x0, 5     — 00500093
//ADD  x2, x1, x1    — 00108133
//ADD  x3, x2, x2    — 00210133
//00500093
//00108133
//00210133



//0x0  ADDI x1, x0, 1     x1=1 
//0x4  ADDI x2, x1, 14    x2=15
//0x8  ADDI  x3, x1,0    x3=1
//0xc   ADDI x1, x1, 1     x1=2
//0x10  ADD  x3, x1, x3    x3=3
//0x14  ADD  x4, x3, x3    x4=6
//0x18  BNE  x2, x3, -12   if x2≠x3 jump to pc=0xc
//00100093
//00E08113
//00008193
//00108093
//003081B3
//00318233
//FE311CE3


# ADDI x1, x0, 3      → 00300093
# ADDI x2, x0, 5      → 00500113
# MUL  x3, x1, x2     → 022081B3
# ADDI x4, x3, 1      → 00118213
//00300093
//00500113
//022081B3
//00118213


// MUL with branching

//00400093   # ADDI x1, x0, 4     x1=4
//00300113   # ADDI x2, x0, 3     x2=3     
//022081B3   # MUL  x3, x1, x2    x3=12
//00118233   # ADD  x4, x3, x1    x4=16
//00820263   # BEQ  x4, x0, +8    not branch
//00100293   # ADDI x5, x0, 1     x5=1
//02518333   # MUL  x6, x3, x5    x6=12  
//00530393   # ADDI x7, x6, 5     x7=17
//FE039EE3   # BNE  x7, x0, -4    loops forever 


// CSR

// addi x1, x0, 5        # x1 = 5
// csrrw x2, mtvec, x1   # x2 = old mtvec (0), mtvec = 5
// csrrs x3, mtvec, x1   # x3 = old mtvec (5), mtvec = 5|5 = 5
// addi x4, x0, 3        # x4 = 3
// csrrw x5, mtvec, x4   # x5 = old mtvec (5), mtvec = 3

00500093   # addi x1, x0, 5
30509173   # csrrw x2, mtvec, x1
3050A1F3   # csrrs x3, mtvec, x1
00300213   # addi x4, x0, 3
305212F3   # csrrw x5, mtvec, x4