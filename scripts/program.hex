// Load Store program
//ADDI x1, x0, 42    — x1 = 42
//ADDI x2, x0, 100   — x2 = base address for memory (byte address)
//SW   x1, 0(x2)     — store 42 to mem[100]
//LW   x3, 0(x2)     — load from mem[100] into x3
//ADDI x4, x3, 1     - Expose the x3 value to verify success
//02A00093
//06400113
//00112023
//00012183
//00118213

//Hazard program
//ADDI x1, x0, 5     — 00500093
//ADD  x2, x1, x1    — 00108133
//ADD  x3, x2, x2    — 00210133
//00500093
//00108133
//00210133



//0x0  ADDI x1, x0, 1     x1=1 
//0x4  ADDI x2, x1, 14    x2=15
//0x8  ADDI  x3, x1,0    x3=1
//0xc   ADDI x1, x1, 1     x1=2
//0x10  ADD  x3, x1, x3    x3=3
//0x14  ADD  x4, x3, x3    x4=6
//0x18  BNE  x2, x3, -12   if x2≠x3 jump to pc=0xc
